generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Market {
  id                  String    @id
  hookAddress         String    @unique
  agentIndex          Int
  agentName           String
  fixtureId           Int
  matchId             String
  propositionId       String
  revealedParams      String
  revealSalt          String
  create2Salt         String
  commitHash          String
  marketDeadline      BigInt
  resolveDeadline     BigInt

  status              String
  createdAt           DateTime  @default(now())
  createdAtBlock      BigInt
  createdTxHash       String

  scheduledRevealAt   DateTime
  revealAttemptedAt   DateTime?
  revealedAt          DateTime?
  revealTxHash        String?
  revealError         String?

  resolvedAt          DateTime?
  resolveTxHash       String?
  resolvedOutcome     Int?

  @@index([fixtureId])
  @@index([agentIndex])
  @@index([status])
  @@index([scheduledRevealAt])
}

model AgentActivity {
  id           Int       @id @default(autoincrement())
  agentIndex   Int
  fixtureId    Int?
  timestamp    DateTime  @default(now())
  eventType    String
  marketId     String?
  metadata     String

  @@index([agentIndex])
  @@index([fixtureId])
  @@index([timestamp])
}

model MatchSession {
  fixtureId    Int       @id
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  finalStatus  String?
}
